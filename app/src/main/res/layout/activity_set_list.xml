<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@drawable/login">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="הגדר רשימה"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etListName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="שם הרשימה"
        android:background="#33000000"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:textColor="#1A1A2E"
        android:textColorHint="#AAAAAA"/>

    <EditText
        android:id="@+id/etFriendPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="מספר טלפון של החבר"
        android:inputType="phone"
        android:background="#33000000"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:textColor="#1A1A2E"
        android:textColorHint="#AAAAAA"/>

    <Button
        android:id="@+id/btnCreateList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="צור רשימה"
        android:backgroundTint="#33000000"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="14dp"/>

</LinearLayout>