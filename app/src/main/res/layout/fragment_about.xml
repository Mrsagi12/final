<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ListTogether"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#4A90D9"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="גרסה 1.0"
            android:textSize="16sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="אפליקציית רשימות קניות משותפת המאפשרת לשני משתמשים לסנכרן רשימה בזמן אמת באמצעות SMS — ללא צורך בשרת או אינטרנט."
            android:textSize="16sp"
            android:textColor="#333333"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="100dp"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="פותח על ידי"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שגיא אלחזוב"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="פרויקט גמר — מגמת מחשבים"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="32dp"/>

        <View
            android:layout_width="100dp"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="טכנולוגיות"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Java • Android Studio • SQLite\nBroadcastReceiver • SMS • SharedPreferences\nRecyclerView • Content Provider"
            android:textSize="14sp"
            android:textColor="#555555"
            android:gravity="center"
            android:lineSpacingMultiplier="1.8"/>

    </LinearLayout>

</ScrollView>